# LLM Provider Configuration
# The system auto-detects available providers.
# Set ONE of these API keys, or use Ollama for local models.

# Cloud Providers (set ONE)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# Local Model (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Force a specific provider (optional)
# LLM_PROVIDER=auto    # auto | openai | anthropic | gemini | ollama | rule_based
# LLM_MODEL=           # Override default model per provider
